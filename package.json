{
  "name": "charity-planner",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/migrate.ts",
    "ingest": "tsx --env-file-if-exists=.env.local scripts/ingest.ts",
    "sanity": "tsx --env-file-if-exists=.env.local scripts/sanity.ts",
    "check:services": "tsx --env-file-if-exists=.env.local scripts/check-services.ts",
    "scenarios": "tsx --env-file-if-exists=.env.local scripts/scenarios.ts",
    "verify:live": "tsx --env-file-if-exists=.env.local scripts/verify-live.ts",
    "verify": "tsx --env-file-if-exists=.env.local scripts/verify.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.0",
    "motion": "^12.40.0",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.17.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.17.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^4.1.8"
  }
}
